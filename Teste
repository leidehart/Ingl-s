function checkListening(i){
  const it=APP.listeningItems[i]; const ans=document.getElementById('lans'+i).value.toLowerCase();
  const keys=it.answer.split(' ').filter(w=>w.length>3); const hits=keys.filter(k=>ans.includes(k)).length;
  const ok = hits>=Math.min(2, keys.length);
  document.getElementById('lfb'+i).innerHTML = `<div class="feedback"><div class="${ok?'correct':'wrong'}">${ok?'Boa compreensão':'Você pegou parte, revise o áudio'}</div><p>Resposta esperada: <strong>${it.answer}</strong></p><p>Dica: ouça de novo e tente capturar palavras-chave, não palavra por palavra.</p></div>`;
  APP.state.listenDone=(APP.state.listenDone||0)+1; save(); addXP(ok?25:12,'listening');
}

let recognition;
function startRecognition(targetId){
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if(!SR){ alert('Seu navegador não suporta reconhecimento de fala. No celular, tente Chrome/Android.'); return; }
  recognition = new SR(); recognition.lang='en-US'; recognition.interimResults=false; recognition.maxAlternatives=1;
  recognition.onresult = e => { document.getElementById(targetId).value = e.results[0][0].transcript; };
  recognition.onerror = e => alert('Erro no reconhecimento de fala: '+e.error);
  recognition.start();
}
function renderSpeaking(){
  document.getElementById('speaking').innerHTML = `<div class="card"><h2>Falar — avaliação automática</h2><p class="muted">A avaliação olha clareza da resposta, palavras-alvo e estruturas. Pronúncia real é aproximada, pois o navegador só devolve a transcrição.</p>${APP.speakingPrompts.map((p,i)=>`
    <div class="lesson-item">
      <div class="row"><span class="tag">${p.level}</span><span class="tag">speaking</span></div>
      <h3>${p.prompt}</h3>
      <p><strong>Foco:</strong> ${p.grammar}</p>
      <button class="btn" onclick="speakText('${p.prompt.replace(/'/g,"\\'")}')">▶ Ouvir pergunta</button>
      <button class="btn secondary" onclick="startRecognition('sp${i}')">🎙️ Responder falando</button>
      <textarea id="sp${i}" placeholder="Sua fala aparecerá aqui. Você também pode digitar."></textarea>
      <button class="btn good" onclick="gradeSpeaking(${i})">Avaliar minha fala</button>
      <div id="sfb${i}"></div>
    </div>`).join('')}</div>`;
}
function gradeSpeaking(i){
  const p=APP.speakingPrompts[i]; const text=document.getElementById('sp'+i).value.trim(); const lower=text.toLowerCase(); const words=lower.split(/\s+/).filter(Boolean);
  const hit=p.target.filter(k=>lower.includes(k)).length; let score=0; score += Math.min(40, words.length*2); score += hit*12;
  if(/\bbecause\b/.test(lower)) score+=10; if(/\b(yesterday|worked|went|slept|watched|studied)\b/.test(lower)) score+=8; if(/\b(i|my|me)\b/.test(lower)) score+=5;
  score=Math.min(100,score);
  const suggestions=[];
  if(words.length<12) suggestions.push('Fale pelo menos 12–20 palavras para treinar fluência.');
  if(!/\bbecause\b/.test(lower) && i>=2) suggestions.push('Use “because” para explicar o motivo.');
  if(i===1 && !/\b(yesterday|worked|went|slept|watched|studied)\b/.test(lower)) suggestions.push('Use passado: worked, went, slept, watched, studied.');
  if(!text) suggestions.push('Grave ou digite sua resposta antes de avaliar.');
  document.getElementById('sfb'+i).innerHTML = `<div class="feedback"><h3>Nota: ${score}/100</h3><p><strong>Pontos fortes:</strong> ${hit} palavra(s)-alvo usadas: ${p.target.filter(k=>lower.includes(k)).join(', ') || 'nenhuma ainda'}.</p><p><strong>Melhore:</strong> ${suggestions.join(' ') || 'Boa resposta. Agora tente falar mais rápido e com uma frase extra.'}</p><p><strong>Modelo natural:</strong> ${modelAnswer(i)}</p></div>`;
  APP.state.speakDone=(APP.state.speakDone||0)+1; save(); addXP(Math.round(score/4),'speaking');
}
function modelAnswer(i){
  return [
    'I work in my field, I go to the gym, and I study English because I want to travel.',
    'Yesterday, I worked, went to the gym, and slept a lot because I was really tired.',
    'I want to learn English because I want to travel and understand movies without Portuguese subtitles.',
    'I recommend this movie because the story is interesting, the characters are strong, and the ending is surprising.'
  ][i];
}

function renderConversation(){
  document.getElementById('conversation').innerHTML = `<div class="card"><h2>Conversar com a Maya</h2><p class="muted">Maya é sua treinadora. Ela responde em inglês simples, corrige uma coisa por vez e fala com voz feminina.</p><div class="chat" id="chat"><div class="msg bot"><strong>Maya:</strong> Hi! Tell me about your day. Use English, even with mistakes. 🙂</div></div><div class="row" style="margin-top:12px"><input class="input" id="chatInput" style="flex:1;min-width:220px" placeholder="Type in English..."><button class="btn secondary" onclick="startRecognition('chatInput')">🎙️</button><button class="btn" onclick="sendChat()">Enviar</button></div></div>`;
}
function sendChat(){
  const input=document.getElementById('chatInput'); const text=input.value.trim(); if(!text) return; addMsg(text,'user'); input.value='';
  const reply = mayaReply(text); setTimeout(()=>{ addMsg('<strong>Maya:</strong> '+reply,'bot'); speakText(reply.replace(/<[^>]+>/g,'')); addXP(8,'conversa'); },300);
}
function addMsg(html, cls){ const chat=document.getElementById('chat'); const d=document.createElement('div'); d.className='msg '+cls; d.innerHTML=html; chat.appendChild(d); chat.scrollTop=chat.scrollHeight; }
function mayaReply(text){
  const l=text.toLowerCase(); let correction='';
  if(/i'm sleeping|i am sleeping/.test(l) && /yesterday/.test(l)) correction='Small correction: say <strong>Yesterday, I slept</strong>, not “I am sleeping”.';
  else if(/grow my speak/.test(l)) correction='Small correction: say <strong>improve my speaking</strong>, not “grow my speak”.';
  else if(/i going/.test(l)) correction='Small correction: say <strong>I am going to...</strong>.';
  else correction='Nice! One natural phrase: <strong>That makes sense.</strong> It means “faz sentido”.';
  const prompts=['What did you do yesterday?','What are you going to do tomorrow?','What kind of movies do you like?','Why do you want to improve your listening?'];
  return `${correction}<br>Now answer: ${prompts[Math.floor(Math.random()*prompts.length)]}`;
}

