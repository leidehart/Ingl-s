function renderQuiz(){
  const pool = APP.questions;
  const ids = [...Array(pool.length).keys()].sort(()=>Math.random()-0.5).slice(0,8);
  window.currentQuizIds = ids;
  document.getElementById('quiz').innerHTML = `<div class="card"><h2>Quiz adaptativo</h2><p class="muted">8 perguntas. Depois de responder, o app explica o tempo verbal, vocabulário natural e estrutura da frase.</p><div id="quizBox">${ids.map((idx,n)=>questionHTML(pool[idx],n)).join('')}</div><button class="btn" onclick="gradeQuiz()">Corrigir quiz</button><div id="quizResult"></div></div>`;
}
function questionHTML(q,n){ return `<div class="question" data-q="${n}"><div class="row"><span class="tag">${q.level}</span><span class="tag">${q.area}</span></div><p><strong>${n+1}. ${q.q}</strong></p>${q.opts.map((o,i)=>`<label class="option"><input type="radio" name="q${n}" value="${i}"> ${esc(o)}</label>`).join('')}<div class="feedback" id="fb${n}" style="display:none"></div></div>`; }
function gradeQuiz(){
  let score=0, detail='';
  window.currentQuizIds.forEach((idx,n)=>{
    const q=APP.questions[idx]; const chosen=document.querySelector(`input[name="q${n}"]:checked`); const fb=document.getElementById('fb'+n);
    const ok=chosen && Number(chosen.value)===q.ans; if(ok) score++;
    fb.style.display='block'; fb.innerHTML = `<div class="${ok?'correct':'wrong'}">${ok?'Correto':'Ajuste necessário'}</div><p><strong>Resposta:</strong> ${esc(q.opts[q.ans])}</p><p>${q.exp}</p>`;
    if(!ok){ APP.state.weak[q.area]=(APP.state.weak[q.area]||0)+1; }
  });
  APP.state.quizDone=(APP.state.quizDone||0)+1; save();
  const xp = score*12 + (score===8?20:0); addXP(xp,'quiz');
  document.getElementById('quizResult').innerHTML = `<div class="feedback"><h3>Resultado: ${score}/8</h3><p>${score>=6?'Muito bom. Continue subindo a dificuldade.':'Revise as explicações dos erros antes de tentar outro quiz.'}</p></div>`;
}

function getVoices(){ return speechSynthesis.getVoices ? speechSynthesis.getVoices() : []; }
function preferredVoice(){
  const voices = getVoices();
  if(APP.state.voiceURI){ const v=voices.find(v=>v.voiceURI===APP.state.voiceURI); if(v) return v; }
  return voices.find(v => /female|woman|samantha|victoria|zira|google uk english female|maria|joana/i.test(v.name)) || voices.find(v=>/en/i.test(v.lang)) || voices[0];
}
function speakText(text, lang='en-US'){
  if(!('speechSynthesis' in window)){ alert('Seu navegador não suporta voz. Tente Chrome ou Edge.'); return; }
  speechSynthesis.cancel(); const u = new SpeechSynthesisUtterance(text); const v=preferredVoice(); if(v) u.voice=v; u.lang = v?.lang || lang; u.rate = APP.state.rate || .9; speechSynthesis.speak(u);
}
function renderListening(){
  document.getElementById('listening').innerHTML = `<div class="card"><h2>Ouvir — modo filmes</h2><p class="muted">Escute sem ler primeiro. Depois responda. Use velocidade mais lenta no começo e suba aos poucos.</p>${APP.listeningItems.map((it,i)=>`
    <div class="lesson-item">
      <div class="row"><span class="tag">${it.level}</span><span class="tag">${it.title}</span></div>
      <h3>${it.title}</h3>
      <button class="btn" onclick="speakText('${it.text.replace(/'/g,"\\'")}')">▶ Ouvir com voz feminina</button>
