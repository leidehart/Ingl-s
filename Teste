<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LevelUp English — A2 para Filmes</title>
  <style>
    :root {
      --bg: #0f1224;
      --panel: #171b33;
      --panel2: #20264a;
      --text: #f7f7ff;
      --muted: #b9bdd7;
      --accent: #ffb84d;
      --accent2: #7ee7d7;
      --good: #87f59c;
      --bad: #ff8a8a;
      --line: rgba(255,255,255,.12);
      --shadow: 0 20px 50px rgba(0,0,0,.35);
      --radius: 22px;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: radial-gradient(circle at top left, rgba(126,231,215,.18), transparent 32%),
                  radial-gradient(circle at top right, rgba(255,184,77,.16), transparent 28%),
                  var(--bg);
      color: var(--text);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      min-height: 100vh;
    }
    header {
      padding: 22px 18px 8px;
      position: sticky;
      top: 0;
      background: linear-gradient(to bottom, rgba(15,18,36,.98), rgba(15,18,36,.86));
      backdrop-filter: blur(12px);
      z-index: 10;
      border-bottom: 1px solid var(--line);
    }
    .topbar { display: flex; align-items: center; justify-content: space-between; gap: 14px; max-width: 1100px; margin: 0 auto; }
    .brand { display: flex; align-items: center; gap: 12px; }
    .logo { width: 44px; height: 44px; border-radius: 16px; display: grid; place-items: center; background: linear-gradient(135deg, var(--accent), #ff6ba6); color: #151515; font-weight: 900; box-shadow: var(--shadow); }
    h1 { font-size: clamp(22px, 5vw, 34px); margin: 0; letter-spacing: -.04em; }
    .subtitle { margin: 3px 0 0; color: var(--muted); font-size: 14px; }
    .pill { display: inline-flex; align-items: center; gap: 7px; border: 1px solid var(--line); background: rgba(255,255,255,.06); border-radius: 999px; padding: 8px 11px; color: var(--muted); font-size: 13px; white-space: nowrap; }
    nav { max-width: 1100px; margin: 16px auto 0; display: flex; gap: 8px; overflow-x: auto; padding-bottom: 8px; }
    nav button { border: 1px solid var(--line); color: var(--text); background: rgba(255,255,255,.05); border-radius: 999px; padding: 11px 14px; cursor: pointer; white-space: nowrap; font-weight: 700; }
    nav button.active { background: var(--accent); color: #151515; border-color: transparent; }
    main { max-width: 1100px; margin: 0 auto; padding: 20px 16px 70px; }
    .grid { display: grid; gap: 16px; }
    .grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    @media (max-width: 800px) { .grid.two, .grid.three { grid-template-columns: 1fr; } .topbar { align-items: flex-start; } .hide-mobile { display:none; } }
    .card { background: linear-gradient(180deg, rgba(255,255,255,.075), rgba(255,255,255,.035)); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); padding: 18px; }
    .card h2, .card h3 { margin: 0 0 10px; letter-spacing: -.025em; }
    .muted { color: var(--muted); }
    .small { font-size: 13px; }
    .big { font-size: clamp(28px, 8vw, 54px); font-weight: 900; letter-spacing: -.06em; margin: 8px 0; }
    .progress { height: 13px; background: rgba(255,255,255,.09); border-radius: 999px; overflow: hidden; border: 1px solid var(--line); }
    .bar { height: 100%; width: 0%; background: linear-gradient(90deg, var(--accent2), var(--accent)); border-radius: 999px; transition: width .4s ease; }
    .level-row { display: grid; grid-template-columns: 72px 1fr auto; gap: 12px; align-items: center; padding: 12px; border-radius: 18px; background: rgba(255,255,255,.045); border: 1px solid var(--line); margin: 9px 0; }
    .badge { background: var(--panel2); border: 1px solid var(--line); padding: 8px 10px; border-radius: 12px; font-weight: 900; text-align:center; }
    .level-row.unlocked .badge { background: rgba(126,231,215,.17); color: var(--accent2); }
    .level-row.current { outline: 2px solid var(--accent); }
    .btn { border: 0; background: var(--accent); color: #161616; border-radius: 14px; padding: 12px 14px; font-weight: 900; cursor: pointer; box-shadow: 0 10px 24px rgba(255,184,77,.18); }
    .btn.secondary { background: rgba(255,255,255,.08); color: var(--text); border: 1px solid var(--line); box-shadow: none; }
    .btn.good { background: var(--accent2); }
    .btn.danger { background: var(--bad); }
    .btn:disabled { opacity:.45; cursor:not-allowed; }
    .row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .input, textarea, select { width: 100%; border: 1px solid var(--line); background: rgba(0,0,0,.18); color: var(--text); border-radius: 14px; padding: 12px; font: inherit; }
    textarea { min-height: 110px; resize: vertical; }
    .tab { display: none; }
    .tab.active { display: block; animation: fade .22s ease; }
    @keyframes fade { from { opacity:.2; transform: translateY(8px); } to { opacity:1; transform:none; } }
    .question { padding: 14px; border: 1px solid var(--line); border-radius: 18px; background: rgba(0,0,0,.12); margin: 14px 0; }
    .option { display: block; margin: 9px 0; padding: 11px; border: 1px solid var(--line); border-radius: 14px; background: rgba(255,255,255,.05); cursor: pointer; }
    .option input { margin-right: 8px; }
    .feedback { margin-top: 10px; padding: 12px; border-radius: 14px; border: 1px solid var(--line); background: rgba(255,255,255,.055); }
    .correct { color: var(--good); font-weight: 900; }
    .wrong { color: var(--bad); font-weight: 900; }
    .tag { display:inline-flex; align-items:center; border-radius: 999px; padding: 5px 9px; background: rgba(126,231,215,.12); color: var(--accent2); border: 1px solid rgba(126,231,215,.25); font-size: 12px; font-weight: 800; margin: 3px; }
    .chat { height: 350px; overflow-y: auto; border: 1px solid var(--line); border-radius: 20px; padding: 12px; background: rgba(0,0,0,.13); }
    .msg { max-width: 88%; margin: 10px 0; padding: 11px 12px; border-radius: 18px; line-height: 1.4; }
    .bot { background: rgba(126,231,215,.14); border: 1px solid rgba(126,231,215,.25); }
    .user { background: rgba(255,184,77,.16); border: 1px solid rgba(255,184,77,.25); margin-left: auto; }
    .divider { height: 1px; background: var(--line); margin: 18px 0; }
    .lesson-item { padding: 14px; border: 1px solid var(--line); border-radius: 18px; background: rgba(255,255,255,.04); margin: 10px 0; }
    .checklist label { display:block; padding:9px 0; }
    .footer-note { color: var(--muted); font-size: 12px; margin-top: 14px; }
    .kpi { padding: 14px; border: 1px solid var(--line); border-radius: 18px; background: rgba(255,255,255,.04); }
    .kpi strong { font-size: 26px; display:block; letter-spacing:-.04em; }
    code { background: rgba(0,0,0,.28); padding: 2px 5px; border-radius: 6px; }
  </style>
</head>
<body>
  <header>
    <div class="topbar">
      <div class="brand">
        <div class="logo">EN</div>
        <div>
          <h1>LevelUp English</h1>
          <p class="subtitle">Seu app A2 → B1/B2, com voz, fala, filmes e revisão quinzenal.</p>
        </div>
      </div>
      <div class="pill hide-mobile" id="todayPill">Dia 1 • A2</div>
    </div>
    <nav id="nav"></nav>
  </header>

  <main>
    <section class="tab active" id="dashboard"></section>
    <section class="tab" id="levels"></section>
    <section class="tab" id="lessons"></section>
    <section class="tab" id="quiz"></section>
    <section class="tab" id="listening"></section>
    <section class="tab" id="speaking"></section>
    <section class="tab" id="conversation"></section>
    <section class="tab" id="review"></section>
    <section class="tab" id="settings"></section>
  </main>

<script>
const APP = {
  state: JSON.parse(localStorage.getItem('levelupState') || '{}'),
  tabs: [
    ['dashboard','Início'], ['levels','Levels'], ['lessons','Lições'], ['quiz','Quiz'],
    ['listening','Ouvir'], ['speaking','Falar'], ['conversation','Conversar'], ['review','Avaliação'], ['settings','Ajustes']
  ],
  levels: [
    {id:'A2.0', min:0, title:'Base A2', desc:'Rotina, presente, frases simples, sobrevivência em viagem.'},
    {id:'A2.1', min:180, title:'Passado e futuro', desc:'Contar o que aconteceu e planejar o que vai fazer.'},
    {id:'A2.2', min:420, title:'Frases maiores', desc:'Conectar ideias com because, so, but, when, before, after.'},
    {id:'A2+', min:720, title:'Pré-B1', desc:'Mais naturalidade, perguntas melhores e listening com contexto.'},
    {id:'B1.1', min:1100, title:'Intermediário real', desc:'Explicar opinião, contar histórias e falar de trabalho/viagens.'},
    {id:'B1.2', min:1550, title:'B1 forte', desc:'Entender falas claras, podcasts fáceis e cenas simples.'},
    {id:'B1+', min:2100, title:'Ponte para B2', desc:'Velocidade, phrasal verbs comuns, séries com legenda em inglês.'},
    {id:'B2.0', min:2750, title:'Filmes em dialeto padrão', desc:'Entender a maioria do conteúdo padrão com menos esforço.'}
  ],
  modules: [
    {week:1, level:'A2.0', theme:'Rotina + Simple Present', grammar:'Simple Present: I work, she works, do/does.', vocab:['I work in my field','I go to the gym','I usually wake up early','I need to improve my English'], structure:'Sujeito + verbo + complemento. Ex: I work in my field.'},
    {week:2, level:'A2.1', theme:'Ontem + Simple Past', grammar:'Simple Past: worked, went, slept, watched. Use para tempo acabado: yesterday, last week.', vocab:['I slept a lot','I went to the gym','I was really tired','I watched a horror movie'], structure:'Yesterday + sujeito + verbo no passado. Ex: Yesterday, I slept a lot.'},
    {week:3, level:'A2.1', theme:'Planos + Going to', grammar:'Be going to: I am going to study. Use para planos/intenção.', vocab:['I am going to travel','I am going to work','I am going to study for one hour','I am going to improve my listening'], structure:'Sujeito + am/is/are + going to + verbo base.'},
    {week:4, level:'A2.2', theme:'Conectar ideias', grammar:'Because, so, but, and, when. Faça frases mais longas sem complicar.', vocab:['because I was tired','so I stayed home','but I want to improve','when I travel'], structure:'Ideia 1 + conector + ideia 2. Ex: I studied because I want to travel.'},
    {week:5, level:'A2+', theme:'Perguntas naturais', grammar:'Question forms: do/does/did/are/is/can. Ordem: auxiliar + sujeito + verbo.', vocab:['What do you do?','Where did you go?','How can I get there?','Could you repeat that?'], structure:'Auxiliar + sujeito + verbo? Ex: Where do you live?'},
    {week:6, level:'A2+', theme:'Viagem e sobrevivência', grammar:'Can/could/would like. Pedidos educados e problemas em viagem.', vocab:['I would like to check in','Could you help me?','I’m looking for the station','I have a reservation'], structure:'Could you + verbo? / I would like + noun/to verb.'},
    {week:7, level:'B1.1', theme:'Present Perfect básico', grammar:'Have/has + past participle. Experiências: I have been, I have never tried.', vocab:['I have never been abroad','I have already booked it','I have studied English for three months','I haven’t watched it yet'], structure:'Sujeito + have/has + particípio + complemento.'},
    {week:8, level:'B1.1', theme:'Opiniões e justificativas', grammar:'I think / I believe / In my opinion + reason. Use because, however, although.', vocab:['I think it is useful','In my opinion','However, it is difficult','Although I am tired'], structure:'Opinião + razão + exemplo. Ex: I think English is important because I want to travel.'},
    {week:9, level:'B1.2', theme:'Listening de séries', grammar:'Contrações, reduções e fala natural: gonna, wanna, kinda, gotta.', vocab:['I’m gonna go','I wanna watch something','That sounds scary','What happened?'], structure:'Reconhecer fala reduzida; escrever formal: I am going to / I want to.'},
    {week:10, level:'B1.2', theme:'Narrativas', grammar:'Past continuous + simple past: I was watching TV when she called.', vocab:['I was watching a movie','when my phone rang','while I was studying','suddenly'], structure:'Past continuous para contexto + simple past para ação principal.'},
    {week:11, level:'B1+', theme:'Condição e conselhos', grammar:'First conditional: If it rains, I will stay home. Should/must/have to.', vocab:['You should practice every day','If I travel, I will speak English','I have to improve my listening'], structure:'If + present, will + verb.'},
    {week:12, level:'B1+', theme:'Modo filme', grammar:'Inferir pelo contexto, reconhecer emoções, tom, intenção e chunks.', vocab:['Are you kidding me?','I can’t believe it','That makes sense','It depends'], structure:'Não traduza palavra por palavra; entenda blocos de sentido.'}
  ],
  questions: [
    {area:'tempo verbal', level:'A2', q:'Choose the best sentence for “Ontem eu dormi muito porque estava cansada.”', opts:['Yesterday I sleep a lot because I am tired.','Yesterday I slept a lot because I was tired.','Yesterday I was sleep a lot because I tired.','Yesterday I sleeping so much because I was tired.'], ans:1, exp:'Use Simple Past com yesterday: slept. Para estado no passado, use was/were: I was tired. Estrutura: Yesterday + sujeito + verbo no passado + because + sujeito + was/were + adjetivo.'},
    {area:'vocabulário natural', level:'A2', q:'What is the most natural way to say “quero melhorar minha fala”?', opts:['I want to grow my speak.','I want to improve my speaking.','I want to increase my speak.','I want to make bigger my speech.'], ans:1, exp:'Em inglês natural, dizemos improve my speaking. Speak é verbo; speaking pode ser habilidade/atividade.'},
    {area:'estrutura da frase', level:'A2', q:'Choose the correct question.', opts:['Where you live?','Where do you live?','Where does you live?','Where are you live?'], ans:1, exp:'Pergunta no Simple Present com you precisa de do: Where + do + you + live?'},
    {area:'tempo verbal', level:'A2', q:'Tomorrow, I ___ work and then to the gym.', opts:['go','went','am going to','was going'], ans:2, exp:'Tomorrow indica futuro. Use be going to para plano: I am going to work and then to the gym.'},
    {area:'vocabulário natural', level:'A2', q:'Which sentence sounds most natural?', opts:['I study English for a travel.','I study English for traveling.','I study English to a travel.','I study English for make travel.'], ans:1, exp:'Travel como ideia geral não usa “a” aqui. Natural: for traveling ou because I want to travel.'},
    {area:'estrutura', level:'A2', q:'Complete: I like horror and romance ___.', opts:['movie','movies','watch','seeing'], ans:1, exp:'Quando fala de categoria geral, use plural: horror and romance movies.'},
    {area:'tempo verbal', level:'A2+', q:'I have lived here ___ 2020.', opts:['for','since','during','ago'], ans:1, exp:'Since marca o ponto de início: since 2020. For marca duração: for three years.'},
    {area:'tempo verbal', level:'B1', q:'Choose the best sentence.', opts:['I was watching a movie when my friend called.','I watched a movie when my friend was call.','I am watching a movie when my friend called yesterday.','I was watch a movie when my friend called.'], ans:0, exp:'Past continuous mostra ação em andamento; simple past interrompe: I was watching... when my friend called.'},
    {area:'vocabulário natural', level:'B1', q:'In a conversation, “That makes sense” means:', opts:['Isso faz sentido.','Isso está caro.','Isso é obrigatório.','Isso está quebrado.'], ans:0, exp:'Chunk muito comum em filmes e conversas: That makes sense = faz sentido.'},
    {area:'estrutura', level:'B1', q:'Choose the best way to give an opinion with reason.', opts:['I think English important because travel.','I think English is important because I want to travel.','In my think, English important for travel.','I am think English is important to travel.'], ans:1, exp:'Estrutura clara: I think + sentence + because + reason.'},
    {area:'listening/filmes', level:'B1', q:'“I’m gonna leave” is the informal spoken form of:', opts:['I am going to leave.','I have gone to leave.','I am leaving yesterday.','I will left.'], ans:0, exp:'Gonna = going to na fala informal. Em escrita formal, prefira going to.'},
    {area:'tempo verbal', level:'B1', q:'If it rains tomorrow, I ___ at home.', opts:['stay','stayed','will stay','was staying'], ans:2, exp:'First conditional: If + present simple, will + verb.'},
    {area:'estrutura', level:'A2+', q:'Which sentence connects ideas best?', opts:['I was tired. I slept a lot.','I slept a lot because I was tired.','Because tired I slept much.','I slept because I tired.'], ans:1, exp:'Because conecta causa. Em inglês precisa de sujeito + verbo: because I was tired.'},
    {area:'vocabulário natural', level:'B1', q:'What does “Could you repeat that?” mean?', opts:['Você pode repetir isso?','Você pode apagar isso?','Você pode comprar isso?','Você pode traduzir isso?'], ans:0, exp:'Frase essencial em viagem e conversação. Could you...? é educado.'},
    {area:'tempo verbal', level:'B1', q:'I ___ never ___ to London.', opts:['have / been','has / gone','did / been','was / go'], ans:0, exp:'Present perfect para experiência: I have never been to London.'},
    {area:'estrutura', level:'B1', q:'Which version is more natural?', opts:['Although I was tired, I kept studying.','Although I tired, I kept study.','Although I was tired, I keep studied.','Although tired was I, I studied kept.'], ans:0, exp:'Although = embora. Depois: sujeito + verbo. Kept + verbo com -ing: kept studying.'},
    {area:'vocabulário natural', level:'A2+', q:'“I’m looking for the station” means:', opts:['Estou procurando a estação.','Estou olhando a estação.','Estou esperando a estação.','Estou saindo da estação.'], ans:0, exp:'Look for = procurar. Não traduza palavra por palavra: look ≠ sempre olhar.'},
    {area:'tempo verbal', level:'A2+', q:'She usually ___ coffee, but yesterday she ___ tea.', opts:['drinks / drank','drink / drank','drank / drinks','drinks / drinked'], ans:0, exp:'Usually pede presente: she drinks. Yesterday pede passado irregular: drank.'},
    {area:'estrutura', level:'B1+', q:'Choose the sentence with the best flow.', opts:['I want travel but I no speak English good.','I want to travel, but I don’t speak English very well yet.','I want traveling but I am not speak English good.','I want travel, however I don’t speaking good.'], ans:1, exp:'Want + to verb. Negative: don’t + base verb. Very well é mais natural que good para descrever speak.'},
    {area:'listening/filmes', level:'B1+', q:'In movies, “Are you kidding me?” usually means:', opts:['Você está brincando comigo? / Sério isso?','Você está me ensinando?','Você está me procurando?','Você está atrasado?'], ans:0, exp:'Chunk comum para surpresa/irritação. Em filmes, o tom ajuda muito.'}
  ],
  listeningItems: [
    {level:'A2', title:'Daily routine', text:'Every morning, I wake up at seven. I work in my field during the day, and after work I go to the gym. At night, I study English because I want to travel next year.', ask:'Why does she study English?', answer:'because she wants to travel'},
    {level:'A2+', title:'Yesterday', text:'Yesterday was a busy day. I worked until six, went to the gym, and then watched a horror movie. I slept a lot because I was really tired.', ask:'Why did she sleep a lot?', answer:'because she was tired'},
    {level:'B1', title:'Travel problem', text:'I arrived at the airport early, but my flight was delayed. I asked the woman at the desk for help, and she told me to check the screen every thirty minutes.', ask:'What was the problem?', answer:'the flight was delayed'},
    {level:'B1+', title:'Movie dialogue style', text:'I know this sounds strange, but I have seen that man before. He was standing outside my house last night, and now he is here again.', ask:'Why is the speaker worried?', answer:'she has seen the man before'}
  ],
  speakingPrompts: [
    {level:'A2', prompt:'Tell me about your routine. Use: I work, I go, I study.', target:['work','go','study'], grammar:'Use Simple Present for routine.'},
    {level:'A2+', prompt:'Tell me what you did yesterday. Use at least two past verbs.', target:['yesterday','worked','went','slept','watched','studied'], grammar:'Use Simple Past: worked, went, slept, watched.'},
    {level:'B1', prompt:'Explain why you want to learn English and give one example.', target:['because','travel','improve','speaking','listening'], grammar:'Use I want to... because...'},
    {level:'B1+', prompt:'Describe a movie you like and explain why you recommend it.', target:['movie','because','story','characters','recommend'], grammar:'Give opinion + reason + example.'}
  ]
};

function initState() {
  const s = APP.state;
  if (!s.started) {
    APP.state = { started: new Date().toISOString(), xp: 0, streak: 1, quizDone: 0, listenDone: 0, speakDone: 0, reviews: [], weak: {}, name: 'Você', dayOffset: 0, voiceURI: '', rate: .9 };
    save();
  }
}
function save(){ localStorage.setItem('levelupState', JSON.stringify(APP.state)); }
function getDay(){ const start = new Date(APP.state.started); const now = new Date(); return Math.max(1, Math.floor((now - start)/86400000)+1 + (APP.state.dayOffset||0)); }
function getXP(){ return APP.state.xp || 0; }
function currentLevel(){ let cur = APP.levels[0]; APP.levels.forEach(l => { if (getXP() >= l.min) cur = l; }); return cur; }
function addXP(n, reason=''){ APP.state.xp = getXP() + n; save(); renderAll(); if(reason) toast(`+${n} XP — ${reason}`); }
function toast(text){ const el=document.createElement('div'); el.textContent=text; el.style.cssText='position:fixed;left:50%;bottom:20px;transform:translateX(-50%);background:#ffb84d;color:#111;padding:12px 16px;border-radius:999px;font-weight:900;box-shadow:0 15px 35px rgba(0,0,0,.35);z-index:99'; document.body.appendChild(el); setTimeout(()=>el.remove(),1800); }
function esc(s){ return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

function setupNav(){
  const nav = document.getElementById('nav');
  nav.innerHTML = APP.tabs.map(([id,label]) => `<button data-tab="${id}" class="${id==='dashboard'?'active':''}">${label}</button>`).join('');
  nav.addEventListener('click', e => {
    const btn = e.target.closest('button[data-tab]'); if(!btn) return;
    document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    document.getElementById(btn.dataset.tab).classList.add('active');
    window.scrollTo({top:0, behavior:'smooth'});
  });
}

function renderDashboard(){
  const day = getDay(); const level = currentLevel(); const next = APP.levels.find(l=>l.min>getXP()) || APP.levels[APP.levels.length-1];
  const pct = next.min === level.min ? 100 : Math.min(100, Math.round(((getXP()-level.min)/(next.min-level.min))*100));
  const week = Math.min(12, Math.ceil(day/7)); const mod = APP.modules[week-1];
  const nextReview = Math.ceil(day/14)*14; document.getElementById('todayPill').textContent = `Dia ${day} • ${level.id}`;
  document.getElementById('dashboard').innerHTML = `
    <div class="grid two">
      <div class="card">
        <span class="tag">nível atual</span><span class="tag">meta: filmes sem legenda PT</span>
        <h2>Você está em <span style="color:var(--accent)">${level.id}</span> — ${level.title}</h2>
        <p class="muted">Seu foco agora: sair do A2 com base firme e construir escuta real para B1/B2. O app dá XP por estudo, quiz, listening, speaking e revisão.</p>
        <div class="big">${getXP()} XP</div>
        <div class="progress"><div class="bar" style="width:${pct}%"></div></div>
        <p class="small muted">Progresso até ${next.id}: ${pct}%</p>
        <div class="row"><button class="btn" onclick="goTab('lessons')">Começar lição de hoje</button><button class="btn secondary" onclick="goTab('review')">Avaliação quinzenal</button></div>
      </div>
      <div class="card">
        <h3>Plano de hoje — ${mod.theme}</h3>
        <p><strong>Gramática:</strong> ${mod.grammar}</p>
        <p><strong>Vocabulário natural:</strong></p>
        ${mod.vocab.map(v=>`<span class="tag">${v}</span>`).join('')}
        <p><strong>Estrutura:</strong> ${mod.structure}</p>
        <div class="divider"></div>
        <div class="grid three">
