}
function gradeReview(){
  let score=0;
  window.reviewIds.forEach((idx,n)=>{ const q=APP.questions[idx]; const chosen=document.querySelector(`input[name="q${n}"]:checked`); const ok=chosen && Number(chosen.value)===q.ans; if(ok) score++; const fb=document.getElementById('fb'+n); fb.style.display='block'; fb.innerHTML=`<div class="${ok?'correct':'wrong'}">${ok?'Correto':'Revisar'}</div><p>${q.exp}</p>`; if(!ok) APP.state.weak[q.area]=(APP.state.weak[q.area]||0)+1; });
  const sp=(document.getElementById('reviewSpeak').value||'').trim().split(/\s+/).filter(Boolean).length; const total = Math.round((score/10)*70 + Math.min(30, sp));
